RewriteEngine On
RewriteBase /

# 1. www olan adresleri www olmadan yönlendir
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# 2. /public dizinindeki talepleri kök dizine yönlendir
RewriteCond %{THE_REQUEST} \s/public/
RewriteRule ^public/(.*)$ /$1 [L,R=301]

# 3. Ana dizinde mevcut olmayan istekleri public dizinine yönlendir (Front Controller)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ public/$1 [L]

 

# 5. chatbot.php dosyasına yalnızca boxproducer.com alan adından erişim izni ver
<Files "chatbot.php">
    Require host lukskutu.com.tr
</Files>
 <IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access 1 year"
    ExpiresByType image/jpeg "access 1 year"
    ExpiresByType image/gif "access 1 year"
    ExpiresByType image/png "access 1 year"
    ExpiresByType text/css "access 1 month"
    ExpiresByType text/html "access 1 month"
    ExpiresByType application/pdf "access 1 month"
    ExpiresByType text/x-javascript "access 1 month"
    ExpiresByType application/x-shockwave-flash "access 1 month"
    ExpiresByType image/x-icon "access 1 year"
    ExpiresDefault "access 1 month"
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php81” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
